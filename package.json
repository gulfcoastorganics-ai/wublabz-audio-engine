{
  "name": "wublabz",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.20.2",
    "npm": ">=10.5.2"
  },
  "scripts": {
    "preinstall": "if [ \"$npm_config_user_agent\" != \"\" ]; then if ! echo \"$npm_config_user_agent\" | grep -q \"npm/\"; then echo \"\nERROR: This project is standardized on npm. Use 'npm install'.\n\" && exit 1; fi; fi",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "server": "tsx src/wublabz/server.ts"
  },
  "main": "./dist/wublabz/index.js",
  "types": "./dist/wublabz/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/wublabz/index.d.ts",
      "default": "./dist/wublabz/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@fastify/websocket": "^10.0.1",
    "fastify": "^4.28.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
